APP_ENV=dev
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/ollama_dashboard
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ollama_dashboard
OLLAMA_HOST=ollama
OLLAMA_PORT=11434
OLLAMA_CONTAINER_NAME=ollama
PROMETHEUS_ENABLED=false
LOKI_ENABLED=false
COMMAND_GUARD_ENABLED=true
REDIS_URL=redis://redis:6379/0
RATE_LIMIT_DEFAULT_PER_MIN=60
TOKEN_QUOTA_DEFAULT_DAILY=250000
MAX_TOKENS=8192
API_KEY_HEADER=Authorization
